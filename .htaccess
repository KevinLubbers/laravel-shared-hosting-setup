<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        # Disable multi-view matching and directory indexes
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Redirect trailing slashes if not a directory
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [L,R=301]

    # Send all requests to index.php if not a real file/folder
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]

    # Pass Authorization headers for APIs
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

# Prevent directory browsing
Options -Indexes

# Optional: Deny access to sensitive files (just in case)
<FilesMatch "(\.env|\.git|composer\.(json|lock))$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Optional: Allow access to storage symlink (for PDFs/uploads)
# If you use `php artisan storage:link`, no changes needed